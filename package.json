{
    "name": "zenn-contents",
    "version": "1.0.0",
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": "24.11.0",
            "onFail": "download"
        },
        "packageManager": {
            "name": "pnpm",
            "version": "11.8.0",
            "onFail": "download"
        }
    },
    "main": "index.js",
    "scripts": {
        "new": "zenn new:article --emoji 🚗",
        "preview": "zenn preview",
        "lint": "pnpm lint:prettier && pnpm lint:markdownlint && pnpm lint:textlint",
        "lint:markdownlint": "markdownlint -i node_modules '**/*.md'",
        "lint:prettier": "prettier --check '**/*.md'",
        "lint:textlint": "textlint '**/*.md'"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "zenn-cli": "^0.5.1"
    },
    "devDependencies": {
        "markdownlint-cli": "^0.49.0",
        "prettier": "^3.8.4",
        "textlint": "^15.7.1",
        "textlint-filter-rule-comments": "^1.3.0",
        "textlint-rule-preset-ja-technical-writing": "^12.0.2"
    }
}
